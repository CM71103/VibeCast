# Environment Variables for VibeCast
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Google Gemini API Configuration (AI Studio)
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_GENAI_USE_VERTEXAI=False


# Kling AI Configuration
KLING_API_KEY=your-kling-api-key

# VibeCast Configuration
# Set to "true" to use mock responses (no real API calls)
VIBECAST_MOCK_MODE=true

# TTS Voice Selection (default: Kore)
# Available: Aoede, Charon, Fenrir, Kore, Puck, etc.
VIBECAST_TTS_VOICE=Kore
