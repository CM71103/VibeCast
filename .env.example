# Environment Variables for VibeCast
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Google Gemini API Configuration (AI Studio)
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=False

# VibeCast Configuration
# Set to "true" to use mock responses (no real API calls)
VIBECAST_MOCK_MODE=true

# Model selection (default: gemini-2.0-flash-001)
# Options: gemini-2.5-flash, gemini-2.0-flash-001
VIBECAST_MODEL=gemini-2.0-flash-001

# Scene limit: keeps API credit spend predictable (1 = one real scene)
VIBECAST_MAX_SCENES_LIMIT=1

# TTS Voice Selection (default: Kore)
# Available: Aoede, Charon, Fenrir, Kore, Puck, Leda, Orus, Zephyr
VIBECAST_TTS_VOICE=Kore

# YouTube Upload (optional; mock mode works without OAuth)
YOUTUBE_ENABLED=false
YOUTUBE_CLIENT_SECRET_PATH=
YOUTUBE_PRIVACY_STATUS=private
